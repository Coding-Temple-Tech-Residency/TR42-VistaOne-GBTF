# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Environment variables / secrets
.env
.env.*
!.env.example

# Flask / local runtime artifacts
instance/
*.db
*.sqlite
*.sqlite3

# Test / coverage / cache
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log

# Keep migrations, ignore only generated caches
migrations/**/__pycache__/
