# Flask
FLASK_APP=run.py
FLASK_ENV=development

# --- Required ---
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=postgresql://user:password@localhost/vistaone_gbtf

# --- Optional (tests) ---
# If unset, tests fall back to DATABASE_URL
TEST_DATABASE_URL=postgresql://user:password@localhost/vistaone_gbtf_test

# --- Optional (integrations) ---
MAPBOX_ACCESS_TOKEN=
VENDOR_API_BASE_URL=https://api.vendor.com
VENDOR_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Connection Pool (optional, defaults shown) ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis / Caching ---
REDIS_URL=redis://localhost:6379/0
CACHE_TIMEOUT=300

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1