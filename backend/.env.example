# Flask
FLASK_APP=run.py
FLASK_ENV=development

# --- Required ---
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-a-random-string

# Shared remote database (Supabase). Ask a team lead for the password.
# Always include ?sslmode=require for Supabase connections.
# Recommended: use the vistaone_app application role, NOT the postgres superuser.
#   postgresql://vistaone_app:<password>@db.jpxznpggfxfnjhvuvpfm.supabase.co:5432/postgres?sslmode=require
#
# Supabase direct connection (postgres superuser – migrations only):
#   postgresql://postgres:<password>@db.jpxznpggfxfnjhvuvpfm.supabase.co:5432/postgres?sslmode=require
#
# Local postgres (docker compose --profile local-db up):
#   postgresql://vistaone:vistaone_dev@localhost:5432/vistaone_gbtf
DATABASE_URL=postgresql://vistaone_app:change-me@db.jpxznpggfxfnjhvuvpfm.supabase.co:5432/postgres?sslmode=require

# --- Optional (tests) ---
# If unset, tests fall back to DATABASE_URL.
# Point this at a dedicated test schema/database so the shared DB is never touched by the test suite.
# CI uses its own postgres service container and sets this automatically.
TEST_DATABASE_URL=postgresql://vistaone_app:change-me@db.jpxznpggfxfnjhvuvpfm.supabase.co:5432/postgres?sslmode=require

# DB_PASSWORD is no longer required when DATABASE_URL is set.
# Only needed as a local fallback without DATABASE_URL — leave blank if using the URL above.
DB_PASSWORD=

# --- Optional (integrations) ---
MAPBOX_ACCESS_TOKEN=
VENDOR_API_BASE_URL=https://api.vendor.com
VENDOR_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Connection Pool (optional, defaults shown) ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis / Caching ---
REDIS_URL=redis://localhost:6379/0
CACHE_TIMEOUT=300

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1