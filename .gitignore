.idea/
*.iml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (if any at root)
.env
.env.local
.env.*.local

# Secrets
*.pem
*.key
*.crt
*.p12
*.pfx
.secrets/

